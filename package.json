{
  "name": "taskup-cli",
  "version": "2.1.1",
  "description": "CLI para TaskUp MD — Automação via API Supabase",
  "type": "module",
  "private": false,
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/src/index.js",
      "types": "./dist/src/index.d.ts"
    },
    "./cli": {
      "import": "./dist/src/cli/index.js",
      "types": "./dist/src/cli/index.d.ts"
    }
  },
  "bin": {
    "taskup": "./dist/src/cli/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "package.json"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "node --loader ts-node/esm src/cli/index.ts",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.9",
    "@types/node": "^20.19.37",
    "@types/yargs": "^17.0.35",
    "ts-node": "^10.9.0",
    "typescript": "^5.5.0"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.100.0",
    "chalk": "^5.3.0",
    "dotenv": "^17.3.1",
    "inquirer": "^9.2.0",
    "ora": "^8.0.0",
    "table": "^6.8.1",
    "yargs": "^17.7.2"
  }
}
